# Copy this file to .env.local for local development.
# Never commit .env or .env*.local — see .gitignore.
# Real values are configured per-environment in Vercel's dashboard (EIP Section 15).

# Endpoint or service key the Contact action submits to.
# Left unset in Sprint 0 — the contact mechanism itself is a later sprint.
CONTACT_FORM_ENDPOINT=

# Optional, privacy-respecting analytics key (EIP Section 18 rejects heavy
# analytics suites — this is intentionally a single, minimal key, if used at all).
NEXT_PUBLIC_ANALYTICS_ID=

# Canonical site URL, used by the metadata architecture (Section 11) for
# absolute Open Graph URLs and the sitemap.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
